{
  "profiles": [
    {
      "name": "main",
      "commands": [
        {
          "name": "build",
          "execute": [
            "aux4 builder all"
          ],
          "help": {
            "text": "Build the app for all platforms"
          }
        },
        {
          "name": "builder",
          "execute": [
            "profile:builder"
          ],
          "help": {
            "text": "Build the app"
          }
        }
      ]
    },
    {
      "name": "builder",
      "commands": [
        {
          "name": "darwin",
          "execute": [
            "cd ${packageDir} && GOOS=darwin GOARCH=amd64 go build -o package/dist/darwin/amd64/aux4-curl .",
            "cd ${packageDir} && GOOS=darwin GOARCH=arm64 go build -o package/dist/darwin/arm64/aux4-curl ."
          ],
          "help": {
            "text": "Build the app for darwin"
          }
        },
        {
          "name": "linux",
          "execute": [
            "cd ${packageDir} && GOOS=linux GOARCH=amd64 go build -o package/dist/linux/amd64/aux4-curl .",
            "cd ${packageDir} && GOOS=linux GOARCH=arm64 go build -o package/dist/linux/arm64/aux4-curl .",
            "cd ${packageDir} && GOOS=linux GOARCH=386 go build -o package/dist/linux/386/aux4-curl ."
          ],
          "help": {
            "text": "Build the app for linux"
          }
        },
        {
          "name": "windows",
          "execute": [
            "cd ${packageDir} && GOOS=windows GOARCH=amd64 go build -o package/dist/windows/amd64/aux4-curl.exe .",
            "cd ${packageDir} && GOOS=windows GOARCH=arm64 go build -o package/dist/windows/arm64/aux4-curl.exe .",
            "cd ${packageDir} && GOOS=windows GOARCH=386 go build -o package/dist/windows/386/aux4-curl.exe ."
          ],
          "help": {
            "text": "Build the app for windows"
          }
        },
        {
          "name": "all",
          "execute": [
            "aux4 builder darwin",
            "aux4 builder linux",
            "aux4 builder windows"
          ],
          "help": {
            "text": "Build the app for all platforms"
          }
        }
      ]
    }
  ]
}
